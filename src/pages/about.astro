---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Quinobox">
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-white border-b border-neutral-200">
    <div class="container max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold font-display text-primary-900 mb-6">About Quinobox</h1>
      <p class="text-xl text-neutral-600">
        Crafting premium packaging solutions since 2015
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold font-display text-primary-900 mb-6">Our Story</h2>
          <p class="text-neutral-600 mb-4">
            Founded in 2015, Quinobox emerged from a simple vision: to provide Malaysian businesses with access to premium, custom packaging solutions without the premium price tag.
          </p>
          <p class="text-neutral-600 mb-4">
            What started as a small operation has grown into a trusted partner for hundreds of businesses across Malaysia. We've perfected our craft through years of experience, continuous innovation, and an unwavering commitment to quality.
          </p>
          <p class="text-neutral-600">
            Today, we're proud to be one of the most respected packaging providers in Malaysia, serving e-commerce businesses, retailers, SMEs, and enterprises.
          </p>
        </div>
        <div class="aspect-square bg-neutral-100 rounded-lg border border-neutral-200 flex items-center justify-center">
          <span class="text-neutral-400">Company image</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-neutral-50">
    <div class="container">
      <h2 class="text-4xl font-bold font-display text-center text-primary-900 mb-16">Our Values</h2>
      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl mb-4">✓</div>
          <h3 class="font-bold text-primary-900 mb-3">Quality</h3>
          <p class="text-neutral-600">Premium materials and craftsmanship in every box</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="font-bold text-primary-900 mb-3">Partnership</h3>
          <p class="text-neutral-600">True collaboration with our clients for success</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="font-bold text-primary-900 mb-3">Reliability</h3>
          <p class="text-neutral-600">Consistent delivery and dependable service</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🌱</div>
          <h3 class="font-bold text-primary-900 mb-3">Sustainability</h3>
          <p class="text-neutral-600">Eco-conscious materials and practices</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-5xl font-bold font-display text-accent-900 mb-3">500+</div>
          <p class="text-neutral-600">Happy Clients</p>
        </div>
        <div>
          <div class="text-5xl font-bold font-display text-accent-900 mb-3">1M+</div>
          <p class="text-neutral-600">Boxes Delivered</p>
        </div>
        <div>
          <div class="text-5xl font-bold font-display text-accent-900 mb-3">9+</div>
          <p class="text-neutral-600">Years Experience</p>
        </div>
        <div>
          <div class="text-5xl font-bold font-display text-accent-900 mb-3">24h</div>
          <p class="text-neutral-600">Response Time</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-primary-900 text-white text-center">
    <div class="container max-w-3xl">
      <h2 class="text-4xl font-bold font-display mb-6">Join Our Growing Community</h2>
      <p class="text-xl text-neutral-300 mb-8">
        Experience premium packaging backed by years of expertise
      </p>
      <a href="/quote" class="btn bg-accent-900 text-primary-900 btn-lg hover:bg-white">Get Your Quote</a>
    </div>
  </section>

  <style>
    .section {
      padding: 96px 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 64px 0;
      }
    }
  </style>
</Layout>
