---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quinobox — Custom Packaging Solutions">

<style>
  /* ─── TOKENS ─── */
  :root {
    --olive-dark:  #3B4A2F;
    --olive:       #4E6438;
    --olive-mid:   #6B8A4E;
    --olive-lt:    #8FAD6A;
    --olive-pale:  #D4E0C2;
    --olive-wash:  #EEF3E7;
    --yellow:      #F5E033;
    --yellow-dk:   #D4BF00;
    --yellow-lt:   #FBF0A0;
    --ink:         #1E2618;
    --white:       #FAFDF6;
    --muted:       #6B7A5C;
    --border:      #C8D9B0;
    --charcoal:    #1E2618;

    --ff: 'Public Sans', system-ui, sans-serif;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ─── RESET ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--olive-wash);
    color: var(--ink);
    font-family: var(--ff);
    font-size: 18px;
    line-height: 1.65;
    overflow-x: hidden;
  }

  img { display: block; max-width: 100%; }
  a  { color: inherit; text-decoration: none; }

  /* ─── SCROLL REVEAL ─── */
  .reveal {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }
  .reveal.visible { opacity: 1; transform: none; }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 4rem;
    background: transparent;
    transition: background 0.4s ease, backdrop-filter 0.4s ease, box-shadow 0.4s ease;
  }
  nav.scrolled {
    background: rgba(238, 243, 231, 0.94);
    backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-logo {
    font-family: var(--ff);
    font-size: 1.75rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--olive-dark);
    text-transform: lowercase;
  }
  .nav-logo span { color: var(--yellow-dk); }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--olive-dark);
    position: relative;
    transition: color 0.2s;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 2px;
    background: var(--yellow);
    transition: width 0.3s var(--ease-out);
  }
  .nav-links a:hover { color: var(--olive); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    background: var(--yellow) !important;
    color: var(--ink) !important;
    padding: 0.65rem 1.5rem;
    font-weight: 700 !important;
    font-size: 0.88rem !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s !important;
  }
  .nav-cta::after { display: none !important; }
  .nav-cta:hover { background: var(--yellow-dk) !important; transform: translateY(-1px); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 9rem 4rem 5rem 4rem;
    position: relative;
    z-index: 2;
    background: var(--olive-dark);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.8s var(--ease-out) 0.2s forwards;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px; height: 2px;
    background: var(--yellow);
  }

  .hero-title {
    font-family: var(--ff);
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--white);
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.9s var(--ease-out) 0.35s forwards;
  }
  .hero-title em {
    font-style: normal;
    color: var(--yellow);
  }

  .hero-sub {
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--olive-pale);
    max-width: 430px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.9s var(--ease-out) 0.5s forwards;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.9s var(--ease-out) 0.65s forwards;
  }

  .btn-primary {
    background: var(--yellow);
    color: var(--ink);
    padding: 1.1rem 2.5rem;
    font-family: var(--ff);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--yellow-dk); transform: translateY(-2px); }

  .btn-ghost {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--olive-pale);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: gap 0.2s, color 0.2s;
  }
  .btn-ghost:hover { gap: 1rem; color: var(--yellow); }

  /* Hero right — full image */
  .hero-right {
    position: relative;
    overflow: hidden;
  }
  .hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.8);
  }
  .hero-right::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(59,74,47,0.5) 0%, transparent 60%);
  }

  /* Stats bar */
  .hero-stat-strip {
    grid-column: 1 / -1;
    background: var(--yellow);
    display: flex;
    opacity: 0;
    animation: fadeUp 0.8s var(--ease-out) 1s forwards;
  }
  .hero-stat {
    flex: 1;
    padding: 1.75rem 2rem;
    border-right: 1px solid rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-stat:last-child { border-right: none; }
  .stat-number {
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--olive-dark);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--olive);
  }

  /* ─── MARQUEE ─── */
  .marquee-strip {
    background: var(--olive);
    padding: 0.9rem 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .marquee-track {
    display: inline-flex;
    animation: marquee 22s linear infinite;
  }
  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
  }
  .marquee-item span { color: var(--yellow); font-size: 1rem; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ─── SECTION BASE ─── */
  section { position: relative; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 4rem; }

  .section-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--olive-mid);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .section-label::before {
    content: '';
    width: 28px; height: 2px;
    background: var(--yellow);
    flex-shrink: 0;
  }

  .section-title {
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .section-title em {
    font-style: normal;
    color: var(--olive);
  }

  /* ─── PRODUCTS ─── */
  .products {
    padding: 7rem 0;
    background: var(--white);
  }

  .products-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 3rem;
    margin-bottom: 4rem;
  }
  .products-desc {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.8;
    max-width: 420px;
    margin-left: auto;
    padding-bottom: 0.25rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--olive-pale);
  }

  .product-card {
    background: var(--white);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.3s;
    display: flex;
    flex-direction: column;
  }
  .product-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 4px;
    background: var(--yellow);
    transition: width 0.4s var(--ease-out);
  }
  .product-card:hover::before { width: 100%; }
  .product-card:hover { background: var(--olive-wash); }

  /* Product image */
  .product-img-wrap {
    width: 100%;
    height: 220px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
    filter: saturate(0.85);
  }
  .product-card:hover .product-img-wrap img { transform: scale(1.06); }

  .product-body { padding: 2rem 2rem 2.5rem; }

  .product-number {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--olive-mid);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .product-name {
    font-size: 1.55rem;
    font-weight: 900;
    color: var(--olive-dark);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 0.85rem;
  }
  .product-desc {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }
  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--olive);
    border: 1.5px solid var(--olive-pale);
    padding: 0.3rem 0.8rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .product-card:hover .tag {
    border-color: var(--yellow);
    background: var(--yellow-lt);
    color: var(--olive-dark);
  }

  .product-arrow {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    width: 38px; height: 38px;
    background: var(--yellow);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    font-size: 0.9rem;
    transition: background 0.2s, transform 0.2s;
  }
  .product-card:hover .product-arrow {
    background: var(--olive-dark);
    color: var(--yellow);
    transform: rotate(45deg);
  }

  /* ─── WHY ─── */
  .why {
    padding: 7rem 0;
    background: var(--olive-wash);
  }

  .why-inner {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 6rem;
    align-items: start;
  }

  .why-left { position: sticky; top: 6rem; }

  /* Why image */
  .why-img {
    margin-top: 2.5rem;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .why-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.8);
    transition: transform 0.6s var(--ease-out);
  }
  .why-img:hover img { transform: scale(1.04); }

  .features-list { display: flex; flex-direction: column; }

  .feature-item {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 1.25rem;
    padding: 2rem 0;
    border-bottom: 1.5px solid var(--border);
    align-items: start;
    transition: padding-left 0.3s var(--ease-out);
  }
  .feature-item:first-child { border-top: 1.5px solid var(--border); }
  .feature-item:hover { padding-left: 0.75rem; }

  .feature-num {
    font-size: 0.72rem;
    font-weight: 900;
    color: var(--yellow-dk);
    background: var(--yellow-lt);
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .feature-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--olive-dark);
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }
  .feature-text {
    font-size: 0.98rem;
    font-weight: 400;
    color: var(--muted);
    line-height: 1.75;
  }

  /* ─── PROCESS ─── */
  .process {
    padding: 0;
    background: var(--olive-dark);
    color: var(--white);
  }

  /* Process banner image */
  .process-banner {
    width: 100%;
    height: 380px;
    overflow: hidden;
    position: relative;
  }
  .process-banner img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: saturate(0.6) brightness(0.5);
  }
  .process-banner-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }
  .process-banner-text {
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--white);
  }
  .process-banner-text em {
    font-style: normal;
    color: var(--yellow);
  }

  .process-body { padding: 5rem 0 6rem; }

  .process .section-label { color: var(--yellow); }
  .process .section-label::before { background: var(--yellow); }

  .process-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 4rem;
  }
  .process-intro {
    font-size: 1.05rem;
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    line-height: 1.8;
    max-width: 400px;
    margin-left: auto;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5px;
    background: rgba(255,255,255,0.08);
  }
  .step {
    background: var(--olive-dark);
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .step:hover { background: var(--olive); }

  .step-num {
    font-size: 5rem;
    font-weight: 900;
    color: rgba(255,255,255,0.05);
    line-height: 1;
    position: absolute;
    top: 1rem; right: 1rem;
    letter-spacing: -0.05em;
  }
  .step-icon-wrap {
    width: 48px; height: 48px;
    border: 2px solid rgba(245,224,51,0.35);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.5rem;
    color: var(--yellow);
    transition: border-color 0.3s, background 0.3s;
  }
  .step:hover .step-icon-wrap {
    border-color: var(--yellow);
    background: rgba(245,224,51,0.1);
  }
  .step-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }
  .step-text {
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255,255,255,0.45);
    line-height: 1.75;
  }

  /* ─── CUSTOMIZATION ─── */
  .custom {
    padding: 7rem 0;
    background: var(--white);
  }

  .custom-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  /* Custom image collage */
  .custom-visual {
    position: relative;
    height: 520px;
  }
  .custom-img-main {
    position: absolute;
    top: 0; left: 0;
    width: 70%; height: 75%;
    overflow: hidden;
  }
  .custom-img-main img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.85);
  }
  .custom-img-accent {
    position: absolute;
    bottom: 0; right: 0;
    width: 55%; height: 55%;
    overflow: hidden;
    border: 6px solid var(--white);
  }
  .custom-img-accent img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.85);
  }
  .custom-badge {
    position: absolute;
    top: 50%; left: 55%;
    transform: translate(-50%, -50%);
    background: var(--yellow);
    color: var(--ink);
    padding: 1.25rem 1rem;
    text-align: center;
    z-index: 2;
    width: 110px;
  }
  .custom-badge-num {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .custom-badge-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--olive-dark);
    margin-top: 0.25rem;
  }

  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }
  .option-chip {
    background: var(--olive-wash);
    border: 1.5px solid var(--border);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: border-color 0.2s, background 0.2s;
    cursor: default;
  }
  .option-chip:hover {
    border-color: var(--yellow);
    background: var(--yellow-lt);
  }
  .option-dot {
    width: 8px; height: 8px;
    background: var(--yellow-dk);
    flex-shrink: 0;
  }
  .option-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--olive-dark);
  }

  .custom-cta {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .custom-note {
    font-size: 0.88rem;
    font-weight: 400;
    color: var(--muted);
  }

  /* ─── TRUST STRIP ─── */
  .brand-strip {
    padding: 4.5rem 0;
    background: var(--olive);
    text-align: center;
  }
  .brand-strip-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 2.5rem;
  }
  .trust-items {
    display: flex;
    justify-content: center;
    gap: 3.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--white);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .trust-icon {
    width: 22px; height: 22px;
    color: var(--yellow);
    flex-shrink: 0;
  }

  /* ─── CTA ─── */
  .cta-section {
    padding: 0;
    background: var(--olive-dark);
    position: relative;
    overflow: hidden;
  }
  .cta-img {
    width: 100%; height: 500px;
    position: relative;
  }
  .cta-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.5) brightness(0.35);
  }
  .cta-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }
  .cta-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--white);
    margin-bottom: 1.25rem;
  }
  .cta-title em {
    font-style: normal;
    color: var(--yellow);
  }
  .cta-sub {
    font-size: 1.05rem;
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 2.5rem;
  }
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .btn-outline {
    background: transparent;
    color: var(--white);
    padding: 1.1rem 2.5rem;
    font-family: var(--ff);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.06em;
