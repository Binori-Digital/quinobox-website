---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Custom Carton & Gift Box Solutions | Quinobox">
  <!-- Hero Section -->
  <section class="pt-32 pb-24 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center animate-fade-up">
        <h1 class="text-5xl md:text-6xl font-bold font-display text-primary-900 mb-6 leading-tight">
          Premium Custom Boxes for Your Brand
        </h1>
        <p class="text-xl text-neutral-600 mb-12 leading-relaxed">
          Elevate your packaging with bespoke carton and gift box solutions designed for businesses across Malaysia
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="btn btn-primary btn-lg">Request Quote</a>
          <a href="/services" class="btn btn-secondary btn-lg">Explore Services</a>
        </div>
      </div>

      <!-- Hero Image Placeholder -->
      <div class="mt-16 aspect-video bg-neutral-100 rounded-lg border border-neutral-200 flex items-center justify-center">
        <span class="text-neutral-400">Custom packaging showcase</span>
      </div>
    </div>
  </section>

  <!-- Services Highlight Section -->
  <section class="section bg-neutral-50">
    <div class="container">
      <h2 class="text-4xl font-bold font-display text-center text-primary-900 mb-4">What We Offer</h2>
      <p class="text-center text-neutral-600 mb-16 max-w-2xl mx-auto">
        Comprehensive packaging solutions tailored to your business needs
      </p>

      <div class="grid-3">
        <!-- Service 1 -->
        <div class="card">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-6">
            <span class="text-2xl">📦</span>
          </div>
          <h3 class="text-2xl font-bold font-display text-primary-900 mb-3">Custom Carton Boxes</h3>
          <p class="text-neutral-600 mb-4">
            Bespoke cardboard boxes designed and manufactured to your exact specifications with premium finishes
          </p>
          <a href="/services#custom-carton" class="link-underline text-accent-900 font-semibold">Learn More →</a>
        </div>

        <!-- Service 2 -->
        <div class="card">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-6">
            <span class="text-2xl">🎁</span>
          </div>
          <h3 class="text-2xl font-bold font-display text-primary-900 mb-3">Gift Boxes</h3>
          <p class="text-neutral-600 mb-4">
            Elegant and luxurious gift boxes perfect for premium products, special occasions, and brand experiences
          </p>
          <a href="/services#gift-boxes" class="link-underline text-accent-900 font-semibold">Learn More →</a>
        </div>

        <!-- Service 3 -->
        <div class="card">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-6">
            <span class="text-2xl">🏢</span>
          </div>
          <h3 class="text-2xl font-bold font-display text-primary-900 mb-3">Wholesale Solutions</h3>
          <p class="text-neutral-600 mb-4">
            Bulk packaging solutions for businesses, resellers, and enterprises at competitive wholesale prices
          </p>
          <a href="/services#wholesale" class="link-underline text-accent-900 font-semibold">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold font-display text-primary-900 mb-8">Why Choose Quinobox?</h2>
          <ul class="space-y-6">
            <li class="flex gap-4">
              <span class="text-accent-900 text-xl font-bold flex-shrink-0">✓</span>
              <div>
                <h4 class="font-bold text-primary-900 mb-1">Premium Quality</h4>
                <p class="text-neutral-600">Crafted with attention to detail using finest materials</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-accent-900 text-xl font-bold flex-shrink-0">✓</span>
              <div>
                <h4 class="font-bold text-primary-900 mb-1">Full Customization</h4>
                <p class="text-neutral-600">Design, colors, dimensions - everything tailored to your brand</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-accent-900 text-xl font-bold flex-shrink-0">✓</span>
              <div>
                <h4 class="font-bold text-primary-900 mb-1">Fast Turnaround</h4>
                <p class="text-neutral-600">Quick production and delivery without compromising quality</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="text-accent-900 text-xl font-bold flex-shrink-0">✓</span>
              <div>
                <h4 class="font-bold text-primary-900 mb-1">Competitive Pricing</h4>
                <p class="text-neutral-600">Best value for premium packaging across Malaysia</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="aspect-square bg-neutral-100 rounded-lg border border-neutral-200 flex items-center justify-center">
          <span class="text-neutral-400">Quality showcase image</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview Section -->
  <section class="section bg-neutral-50">
    <div class="container">
      <h2 class="text-4xl font-bold font-display text-center text-primary-900 mb-4">Recent Projects</h2>
      <p class="text-center text-neutral-600 mb-16 max-w-2xl mx-auto">
        Showcasing exceptional packaging solutions we've created for businesses
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <a href="/portfolio" class="group">
          <div class="aspect-square bg-neutral-200 rounded-lg overflow-hidden mb-4 border border-neutral-300">
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-neutral-100 to-neutral-200">
              <span class="text-neutral-400">Project 1</span>
            </div>
          </div>
          <h3 class="font-bold text-primary-900 group-hover:text-accent-900 transition-colors">Premium Gift Boxes</h3>
          <p class="text-sm text-neutral-600">Luxury cosmetics packaging</p>
        </a>

        <a href="/portfolio" class="group">
          <div class="aspect-square bg-neutral-200 rounded-lg overflow-hidden mb-4 border border-neutral-300">
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-neutral-100 to-neutral-200">
              <span class="text-neutral-400">Project 2</span>
            </div>
          </div>
          <h3 class="font-bold text-primary-900 group-hover:text-accent-900 transition-colors">Custom Cartons</h3>
          <p class="text-sm text-neutral-600">E-commerce shipping solutions</p>
        </a>

        <a href="/portfolio" class="group">
          <div class="aspect-square bg-neutral-200 rounded-lg overflow-hidden mb-4 border border-neutral-300">
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-neutral-100 to-neutral-200">
              <span class="text-neutral-400">Project 3</span>
            </div>
          </div>
          <h3 class="font-bold text-primary-900 group-hover:text-accent-900 transition-colors">Wholesale Boxes</h3>
          <p class="text-sm text-neutral-600">Bulk retail packaging</p>
        </a>
      </div>

      <div class="text-center mt-12">
        <a href="/portfolio" class="btn btn-secondary btn-lg">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="section bg-white">
    <div class="container">
      <h2 class="text-4xl font-bold font-display text-center text-primary-900 mb-16">What Our Clients Say</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="border-l-4 border-accent-900 pl-6 py-4">
          <p class="text-neutral-600 mb-4 italic">
            "Quinobox transformed our brand's unboxing experience. The quality and attention to detail exceeded expectations."
          </p>
          <div>
            <p class="font-bold text-primary-900">Sarah Chen</p>
            <p class="text-sm text-neutral-600">E-commerce Founder</p>
          </div>
        </div>

        <div class="border-l-4 border-accent-900 pl-6 py-4">
          <p class="text-neutral-600 mb-4 italic">
            "Working with Quinobox was seamless. Fast turnaround, excellent communication, and premium results every time."
          </p>
          <div>
            <p class="font-bold text-primary-900">Ahmad Rashid</p>
            <p class="text-sm text-neutral-600">Retail Business Owner</p>
          </div>
        </div>

        <div class="border-l-4 border-accent-900 pl-6 py-4">
          <p class="text-neutral-600 mb-4 italic">
            "The custom gift boxes we ordered are absolutely stunning. Our customers keep asking about the packaging!"
          </p>
          <div>
            <p class="font-bold text-primary-900">Maya Patel</p>
            <p class="text-sm text-neutral-600">Beauty Brand CEO</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section bg-primary-900 text-white">
    <div class="container max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-bold font-display mb-6">Ready to Elevate Your Packaging?</h2>
      <p class="text-xl text-neutral-300 mb-8">
        Get a custom quote for your box packaging needs. Our team will work with you to create the perfect solution.
      </p>
      <a href="/quote" class="btn bg-accent-900 text-primary-900 hover:bg-white btn-lg">Get Your Quote Today</a>
    </div>
  </section>

  <style>
    .section {
      padding: 96px 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 64px 0;
      }
    }

    .card {
      transition: all 0.3s ease;
    }

    .card:hover {
      transform: translateY(-8px);
    }

    .group:hover h3 {
      color: var(--color-accent);
    }
  </style>
</Layout>
