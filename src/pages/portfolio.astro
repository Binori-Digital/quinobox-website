---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | Quinobox">
  <!-- Header -->
  <section class="pt-32 pb-24 bg-white border-b border-neutral-200">
    <div class="container max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold font-display text-primary-900 mb-6">Our Portfolio</h1>
      <p class="text-xl text-neutral-600">
        Exceptional packaging solutions we've created for businesses across Malaysia
      </p>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-8 mb-16">
        <div class="group cursor-pointer">
          <div class="aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 rounded-lg border border-neutral-200 flex items-center justify-center mb-4 overflow-hidden hover:border-accent-900 transition-colors">
            <span class="text-neutral-400">Project 1</span>
          </div>
          <h3 class="font-bold text-primary-900 text-lg mb-2 group-hover:text-accent-900 transition-colors">Premium Cosmetics Gift Boxes</h3>
          <p class="text-neutral-600 text-sm mb-3">
            Luxury packaging for high-end cosmetics brand. Custom dimensions with premium foil stamping and ribbon closure.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Gift Boxes</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Luxury</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Custom Print</span>
          </div>
        </div>

        <div class="group cursor-pointer">
          <div class="aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 rounded-lg border border-neutral-200 flex items-center justify-center mb-4 overflow-hidden hover:border-accent-900 transition-colors">
            <span class="text-neutral-400">Project 2</span>
          </div>
          <h3 class="font-bold text-primary-900 text-lg mb-2 group-hover:text-accent-900 transition-colors">E-commerce Shipping Boxes</h3>
          <p class="text-neutral-600 text-sm mb-3">
            Custom carton boxes for online retailer. Corrugated design with branded printing and protective padding.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Carton Boxes</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">E-commerce</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Bulk</span>
          </div>
        </div>

        <div class="group cursor-pointer">
          <div class="aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 rounded-lg border border-neutral-200 flex items-center justify-center mb-4 overflow-hidden hover:border-accent-900 transition-colors">
            <span class="text-neutral-400">Project 3</span>
          </div>
          <h3 class="font-bold text-primary-900 text-lg mb-2 group-hover:text-accent-900 transition-colors">Artisan Product Packaging</h3>
          <p class="text-neutral-600 text-sm mb-3">
            Bespoke packaging for artisanal goods. Sustainable materials with minimalist design and natural finishes.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Custom</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Eco-Friendly</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Artisan</span>
          </div>
        </div>

        <div class="group cursor-pointer">
          <div class="aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 rounded-lg border border-neutral-200 flex items-center justify-center mb-4 overflow-hidden hover:border-accent-900 transition-colors">
            <span class="text-neutral-400">Project 4</span>
          </div>
          <h3 class="font-bold text-primary-900 text-lg mb-2 group-hover:text-accent-900 transition-colors">Wholesale Reseller Boxes</h3>
          <p class="text-neutral-600 text-sm mb-3">
            Bulk packaging solution for retail resellers. Cost-effective with white label options and flexible quantities.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Wholesale</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Bulk</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">White Label</span>
          </div>
        </div>

        <div class="group cursor-pointer">
          <div class="aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 rounded-lg border border-neutral-200 flex items-center justify-center mb-4 overflow-hidden hover:border-accent-900 transition-colors">
            <span class="text-neutral-400">Project 5</span>
          </div>
          <h3 class="font-bold text-primary-900 text-lg mb-2 group-hover:text-accent-900 transition-colors">Food & Beverage Boxes</h3>
          <p class="text-neutral-600 text-sm mb-3">
            Food-safe packaging for culinary products. Custom sizing with waterproof coating and branded graphics.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Food-Safe</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Specialty</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Custom</span>
          </div>
        </div>

        <div class="group cursor-pointer">
          <div class="aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 rounded-lg border border-neutral-200 flex items-center justify-center mb-4 overflow-hidden hover:border-accent-900 transition-colors">
            <span class="text-neutral-400">Project 6</span>
          </div>
          <h3 class="font-bold text-primary-900 text-lg mb-2 group-hover:text-accent-900 transition-colors">Electronics Display Boxes</h3>
          <p class="text-neutral-600 text-sm mb-3">
            Premium packaging for electronics with protective inserts. Full-color printing with glossy finish.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Electronics</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Premium</span>
            <span class="text-xs bg-neutral-100 px-3 py-1 rounded-full">Protective</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-primary-900 text-white text-center">
    <div class="container max-w-3xl">
      <h2 class="text-4xl font-bold font-display mb-6">Your Project Deserves Premium Packaging</h2>
      <p class="text-xl text-neutral-300 mb-8">
        Let's create something exceptional for your brand
      </p>
      <a href="/quote" class="btn bg-accent-900 text-primary-900 btn-lg hover:bg-white">Start Your Project</a>
    </div>
  </section>

  <style>
    .section {
      padding: 96px 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 64px 0;
      }
    }
  </style>
</Layout>
