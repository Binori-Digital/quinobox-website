---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Quinobox">
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-white border-b border-neutral-200">
    <div class="container max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold font-display text-primary-900 mb-6">Get In Touch</h1>
      <p class="text-xl text-neutral-600">
        Have questions? We're here to help. Reach out anytime.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold font-display text-primary-900 mb-8">Contact Information</h2>

          <div class="mb-8">
            <h3 class="font-bold text-primary-900 mb-2">Email</h3>
            <a href="mailto:hello@quinobox.com.my" class="text-accent-900 hover:text-primary-900">
              hello@quinobox.com.my
            </a>
          </div>

          <div class="mb-8">
            <h3 class="font-bold text-primary-900 mb-2">Phone</h3>
            <a href="tel:+60168916381" class="text-accent-900 hover:text-primary-900">
              +60 16 891 6381
            </a>
          </div>

          <div class="mb-8">
            <h3 class="font-bold text-primary-900 mb-2">WhatsApp</h3>
            <a href="https://wa.me/60168916381" target="_blank" rel="noopener noreferrer" class="text-accent-900 hover:text-primary-900">
              Chat with us on WhatsApp
            </a>
          </div>

          <div class="mb-8">
            <h3 class="font-bold text-primary-900 mb-2">Location</h3>
            <p class="text-neutral-600">
              Klang, Selangor<br/>
              Malaysia
            </p>
          </div>

          <div>
            <h3 class="font-bold text-primary-900 mb-4">Business Hours</h3>
            <ul class="text-neutral-600 space-y-2">
              <li>Monday - Friday: 8:00 AM - 6:00 PM</li>
              <li>Saturday: 9:00 AM - 3:00 PM</li>
              <li>Sunday: Closed</li>
            </ul>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-3xl font-bold font-display text-primary-900 mb-8">Send us a Message</h2>
          <form class="space-y-6" id="contact-form">
            <div>
              <label for="name" class="block font-bold text-primary-900 mb-2">Your Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="John Doe"
              />
            </div>

            <div>
              <label for="email" class="block font-bold text-primary-900 mb-2">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="john@example.com"
              />
            </div>

            <div>
              <label for="phone" class="block font-bold text-primary-900 mb-2">Phone (Optional)</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="+60 12 345 6789"
              />
            </div>

            <div>
              <label for="message" class="block font-bold text-primary-900 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="Tell us about your packaging needs..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn btn-primary w-full"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Placeholder) -->
  <section class="section bg-neutral-50">
    <div class="container">
      <h2 class="text-3xl font-bold font-display text-center text-primary-900 mb-12">Visit Our Location</h2>
      <div class="w-full h-96 bg-neutral-200 rounded-lg border border-neutral-300 flex items-center justify-center">
        <span class="text-neutral-500">Map will be displayed here</span>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        alert('Thank you for your message! We will get back to you soon.');
        form.reset();
      });
    }
  </script>

  <style>
    .section {
      padding: 96px 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 64px 0;
      }
    }
  </style>
</Layout>
