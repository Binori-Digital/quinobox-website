---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Custom Packaging Services | Quinobox">
  <!-- Hero Section -->
  <section class="pt-32 pb-24 bg-white border-b border-neutral-200">
    <div class="container max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold font-display text-primary-900 mb-6">Our Services</h1>
      <p class="text-xl text-neutral-600">
        Comprehensive packaging solutions designed to meet every business need
      </p>
    </div>
  </section>

  <!-- Custom Carton Boxes -->
  <section id="custom-carton" class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold font-display text-primary-900 mb-6">Custom Carton Boxes</h2>
          <p class="text-neutral-600 mb-4">
            Bespoke cardboard boxes manufactured to your exact specifications. Perfect for shipping, storage, and branding.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Custom dimensions and flute types</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Full color printing and finishing</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Eco-friendly materials available</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Bulk and single batch orders</span>
            </li>
          </ul>
          <a href="/quote" class="btn btn-primary">Request Carton Quote</a>
        </div>
        <div class="aspect-square bg-neutral-100 rounded-lg border border-neutral-200 flex items-center justify-center">
          <span class="text-neutral-400">Carton box showcase</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gift Boxes -->
  <section id="gift-boxes" class="section bg-neutral-50">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-square bg-neutral-100 rounded-lg border border-neutral-200 flex items-center justify-center order-2 md:order-1">
          <span class="text-neutral-400">Gift box showcase</span>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-4xl font-bold font-display text-primary-900 mb-6">Premium Gift Boxes</h2>
          <p class="text-neutral-600 mb-4">
            Luxurious gift boxes designed to make unforgettable first impressions. Elevate your brand with premium packaging.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Elegant designs and finishes</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Ribbon, tissue, and padding options</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Custom inserts and compartments</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Premium foil stamping available</span>
            </li>
          </ul>
          <a href="/quote" class="btn btn-primary">Request Gift Box Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Wholesale Solutions -->
  <section id="wholesale" class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold font-display text-primary-900 mb-6">Wholesale Solutions</h2>
          <p class="text-neutral-600 mb-4">
            Bulk packaging for resellers, retailers, and enterprises. Competitive wholesale pricing without compromising quality.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Bulk order discounts</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Flexible minimum order quantities</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Dedicated account management</span>
            </li>
            <li class="flex gap-3">
              <span class="text-accent-900 font-bold">→</span>
              <span>Fast delivery schedules</span>
            </li>
          </ul>
          <a href="/quote" class="btn btn-primary">Request Wholesale Quote</a>
        </div>
        <div class="aspect-square bg-neutral-100 rounded-lg border border-neutral-200 flex items-center justify-center">
          <span class="text-neutral-400">Wholesale showcase</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="section bg-neutral-50">
    <div class="container">
      <h2 class="text-4xl font-bold font-display text-center text-primary-900 mb-16">Our Process</h2>
      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-900 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6">
            1
          </div>
          <h3 class="font-bold text-primary-900 mb-3">Consultation</h3>
          <p class="text-neutral-600">Discuss your packaging needs and vision</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-900 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6">
            2
          </div>
          <h3 class="font-bold text-primary-900 mb-3">Design</h3>
          <p class="text-neutral-600">Create custom designs tailored to specs</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-900 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6">
            3
          </div>
          <h3 class="font-bold text-primary-900 mb-3">Production</h3>
          <p class="text-neutral-600">Manufacture with quality assurance</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-900 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6">
            4
          </div>
          <h3 class="font-bold text-primary-900 mb-3">Delivery</h3>
          <p class="text-neutral-600">Fast, reliable delivery to your door</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section bg-primary-900 text-white text-center">
    <div class="container max-w-3xl">
      <h2 class="text-4xl font-bold font-display mb-6">Ready to Get Started?</h2>
      <p class="text-xl text-neutral-300 mb-8">
        Let's discuss your packaging needs and find the perfect solution for your business.
      </p>
      <a href="/quote" class="btn bg-accent-900 text-primary-900 btn-lg hover:bg-white">Request a Quote</a>
    </div>
  </section>

  <style>
    .section {
      padding: 96px 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 64px 0;
      }
    }
  </style>
</Layout>
