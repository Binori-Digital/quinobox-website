---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Request a Quote | Quinobox">
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-white border-b border-neutral-200">
    <div class="container max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold font-display text-primary-900 mb-6">Request a Quote</h1>
      <p class="text-xl text-neutral-600">
        Get a custom quote for your packaging needs in minutes
      </p>
    </div>
  </section>

  <!-- Quote Form -->
  <section class="section bg-white">
    <div class="container max-w-2xl">
      <form class="space-y-8" id="quote-form">
        <!-- Personal Info -->
        <fieldset class="border-b border-neutral-200 pb-8">
          <legend class="text-2xl font-bold font-display text-primary-900 mb-6">Your Information</legend>

          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="company" class="block font-bold text-primary-900 mb-2">Company Name *</label>
              <input
                type="text"
                id="company"
                name="company"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="Your Company"
              />
            </div>
            <div>
              <label for="contact-name" class="block font-bold text-primary-900 mb-2">Contact Person *</label>
              <input
                type="text"
                id="contact-name"
                name="contact-name"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="Your Name"
              />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block font-bold text-primary-900 mb-2">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="email@company.com"
              />
            </div>
            <div>
              <label for="phone" class="block font-bold text-primary-900 mb-2">Phone *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="+60 12 345 6789"
              />
            </div>
          </div>
        </fieldset>

        <!-- Product Info -->
        <fieldset class="border-b border-neutral-200 pb-8">
          <legend class="text-2xl font-bold font-display text-primary-900 mb-6">Package Specifications</legend>

          <div class="mb-6">
            <label for="box-type" class="block font-bold text-primary-900 mb-2">Box Type *</label>
            <select
              id="box-type"
              name="box-type"
              required
              class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
            >
              <option value="">Select a box type</option>
              <option value="carton">Custom Carton Boxes</option>
              <option value="gift">Gift Boxes</option>
              <option value="mailer">Mailer Boxes</option>
              <option value="wholesale">Wholesale Boxes</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="grid md:grid-cols-3 gap-6 mb-6">
            <div>
              <label for="length" class="block font-bold text-primary-900 mb-2">Length (cm) *</label>
              <input
                type="number"
                id="length"
                name="length"
                required
                step="0.1"
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="20"
              />
            </div>
            <div>
              <label for="width" class="block font-bold text-primary-900 mb-2">Width (cm) *</label>
              <input
                type="number"
                id="width"
                name="width"
                required
                step="0.1"
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="15"
              />
            </div>
            <div>
              <label for="height" class="block font-bold text-primary-900 mb-2">Height (cm) *</label>
              <input
                type="number"
                id="height"
                name="height"
                required
                step="0.1"
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="10"
              />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="quantity" class="block font-bold text-primary-900 mb-2">Quantity (units) *</label>
              <input
                type="number"
                id="quantity"
                name="quantity"
                required
                min="1"
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
                placeholder="1000"
              />
            </div>
            <div>
              <label for="material" class="block font-bold text-primary-900 mb-2">Material *</label>
              <select
                id="material"
                name="material"
                required
                class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
              >
                <option value="">Select material</option>
                <option value="corrugated">Corrugated Cardboard</option>
                <option value="kraft">Kraft Paper</option>
                <option value="rigid">Rigid Board</option>
                <option value="eco">Eco-Friendly</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
        </fieldset>

        <!-- Additional Info -->
        <fieldset class="border-b border-neutral-200 pb-8">
          <legend class="text-2xl font-bold font-display text-primary-900 mb-6">Additional Details</legend>

          <div class="mb-6">
            <label for="customization" class="block font-bold text-primary-900 mb-2">Customization Needs</label>
            <textarea
              id="customization"
              name="customization"
              rows="4"
              class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
              placeholder="Color printing, logo placement, special finishes, etc..."
            ></textarea>
          </div>

          <div>
            <label for="timeline" class="block font-bold text-primary-900 mb-2">When do you need the boxes?</label>
            <select
              id="timeline"
              name="timeline"
              class="w-full border border-neutral-300 rounded-lg px-4 py-3 focus:border-accent-900 focus:outline-none transition"
            >
              <option value="">Select timeline</option>
              <option value="1week">Within 1 week</option>
              <option value="2weeks">Within 2 weeks</option>
              <option value="1month">Within 1 month</option>
              <option value="flexible">Flexible</option>
            </select>
          </div>
        </fieldset>

        <!-- Submit -->
        <div>
          <button
            type="submit"
            class="btn btn-primary btn-lg w-full md:w-auto"
          >
            Submit Quote Request
          </button>
          <p class="text-neutral-600 text-sm mt-4">
            We'll respond to your quote request within 24 hours with pricing and delivery options.
          </p>
        </div>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('quote-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        alert('Thank you for your quote request! We will contact you within 24 hours.');
        form.reset();
      });
    }
  </script>

  <style>
    .section {
      padding: 96px 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 64px 0;
      }
    }
  </style>
</Layout>
